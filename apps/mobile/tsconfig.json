{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2020",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmitHelpers": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "lib": ["es2020", "dom"],
    "baseUrl": ".",
    "paths": { "~/*": ["app/*"] }
  },
  "exclude": ["node_modules", "platforms"]
}
