{
  "name": "dosthq/guard51-api",
  "description": "Guard51 API \u2014 Security Workforce Management SaaS",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "php-di/php-di": "^7.0",
    "php-di/slim-bridge": "^3.4",
    "doctrine/orm": "^3.3",
    "doctrine/dbal": "^4.2",
    "doctrine/migrations": "^3.8",
    "symfony/validator": "^7.2",
    "symfony/messenger": "^7.2",
    "symfony/cache": "^7.2",
    "firebase/php-jwt": "^6.11",
    "monolog/monolog": "^3.7",
    "predis/predis": "^2.3",
    "league/flysystem": "^3.29",
    "league/flysystem-aws-s3-v3": "^3.29",
    "league/flysystem-local": "^3.29",
    "dompdf/dompdf": "^3.0",
    "zircote/swagger-php": "^4.11",
    "ramsey/uuid": "^4.7",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.9",
    "symfony/console": "^7.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.4",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "autoload": {
    "psr-4": {
      "Guard51\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Guard51\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "php-cs-fixer fix --dry-run --diff",
    "fix": "php-cs-fixer fix",
    "analyse": "phpstan analyse src --level=8",
    "migrate": "doctrine-migrations migrate --no-interaction",
    "migrate:diff": "doctrine-migrations diff",
    "migrate:status": "doctrine-migrations status"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "audit": {
      "ignore": [
        "PKSA-y2cr-5h3j-g3ys"
      ]
    }
  }
}