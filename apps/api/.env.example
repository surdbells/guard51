# Guard51 API Configuration
# Copy to .env and fill in your values

APP_NAME=Guard51
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.guard51.com

# Database (PostgreSQL + PostGIS)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=guard51
DB_USER=guard51
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Paystack (Subscription Billing)
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx

# ZeptoMail (Email)
ZEPTOMAIL_API_KEY=xxx
ZEPTOMAIL_FROM_EMAIL=noreply@guard51.com
ZEPTOMAIL_FROM_NAME=Guard51

# Termii (SMS)
TERMII_API_KEY=xxx
TERMII_SENDER_ID=Guard51

# File Storage
STORAGE_DRIVER=local
STORAGE_PATH=/var/www/guard51/storage
S3_BUCKET=
S3_REGION=
S3_KEY=
S3_SECRET=

# WebSocket Realtime Server
REALTIME_URL=wss://realtime.guard51.com
REALTIME_PORT=3001

# 2FA (TOTP)
TOTP_ISSUER=Guard51

# WhatsApp (360dialog)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Logging
LOG_LEVEL=warning
LOG_PATH=/var/www/guard51/logs
