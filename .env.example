# Guard51 Environment Configuration
# Copy to .env and fill in values

# ── App ──────────────────────────────────────────
APP_ENV=development
APP_NAME=Guard51
APP_URL=http://localhost:8080
APP_DEBUG=true

# ── Database (PostgreSQL + PostGIS) ──────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=guard51
DB_USER=guard51
DB_PASSWORD=guard51_secret

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT Authentication ───────────────────────────
JWT_SECRET=change_me_in_production_use_64_char_random_string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Ports ────────────────────────────────────────
NGINX_PORT=8080
WEB_PORT=4200
REALTIME_PORT=3001

# ── ZeptoMail (Transactional Email) ──────────────
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=noreply@guard51.com
ZEPTOMAIL_FROM_NAME=Guard51

# ── Termii (SMS) ─────────────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=Guard51

# ── Paystack (Subscription Billing) ──────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ── File Storage ─────────────────────────────────
FILE_STORAGE_DRIVER=local
AWS_S3_BUCKET=
AWS_S3_REGION=af-south-1
AWS_S3_KEY=
AWS_S3_SECRET=

# ── Google Maps (Live Tracking) ──────────────────
GOOGLE_MAPS_API_KEY=
